# Copy this file to `.env` and fill in the token.

# Your CampHawk site.
CAMPHAWK_URL=https://camphawk.app

# MASTER token — the SAME value you set as AUTOCART_TOKEN in Vercel.
# One token for the whole bot; it pulls every enrolled user's openings.
AUTOCART_TOKEN=replace-with-a-long-random-string

# How often to check for openings (ms) and how far back to look (minutes).
# Polling is a tiny HTTP request (browsers only open on a real hit), so a low
# value barely uses any resources — 5s keeps reaction time snappy.
POLL_MS=5000
WINDOW_MIN=15

# How many browsers may be open at once (1 = lowest RAM; raise on a beefier box).
MAX_CONCURRENCY=1

# On a Raspberry Pi (ARM), Playwright's bundled Chromium can be flaky — install the
# system browser (`sudo apt install chromium`) and uncomment this to use it:
# CHROME_CHANNEL=chromium

# --- Remote sign-in (Option C: friends sign in from any computer) ------------
# 'local'  = the bot opens a login window on THIS machine (default).
# 'remote' = sign-in is done in the browser via broker.mjs; the bot won't open
#            its own login windows. Run `npm run broker` alongside `npm start`.
# LOGIN_MODE=remote
#
# Port the broker listens on (exposed to the web through a tunnel — see README).
# BROKER_PORT=8787
#
# The broker runs its browser headless by default (nobody watches the mini PC;
# the sign-in is streamed to the friend's browser). To watch the real window while
# debugging on a machine with a display, set:
# BROKER_HEADLESS=0
